import { NextResponse } from "next/server";
import { z } from "zod";
import { searchChunks } from "@/lib/service/search/vector-search";
import { answerWithRag } from "@/lib/service/chat/rag-chat";

// ---------------------------------------------------------------------------
// Input / Output schemas (zod)
// ---------------------------------------------------------------------------

const querySchema = z.object({
  /** The user's natural-language question. */
  question: z.string().min(1),
  /** Document IDs to scope the vector search. Must be non-empty. */
  documentIds: z.array(z.string().min(1)).min(1),
  /** Number of chunks to retrieve (default 5). */
  topK: z.coerce.number().int().positive().max(20).default(5),
});

export type {{namePascal}}QueryInput = z.infer<typeof querySchema>;

// ---------------------------------------------------------------------------
// GET — retrieve top-K chunks relevant to a question (non-streaming)
// ---------------------------------------------------------------------------

export async function GET(req: Request) {
  const { searchParams } = new URL(req.url);
  const raw = {
    question: searchParams.get("question") ?? undefined,
    documentIds: searchParams.getAll("documentIds"),
    topK: searchParams.get("topK") ?? undefined,
  };

  const parsed = querySchema.safeParse(raw);
  if (!parsed.success) {
    return NextResponse.json(
      { error: "invalid input", details: parsed.error.flatten() },
      { status: 400 },
    );
  }

  const chunks = await searchChunks(parsed.data.question, {
    documentIds: parsed.data.documentIds,
    topK: parsed.data.topK,
  });

  return NextResponse.json({ chunks });
}

// ---------------------------------------------------------------------------
// POST — RAG query: vector search → LLM streaming answer
// ---------------------------------------------------------------------------

export async function POST(req: Request) {
  let body: unknown;
  try {
    body = await req.json();
  } catch {
    return NextResponse.json({ error: "invalid json" }, { status: 400 });
  }

  const parsed = querySchema.safeParse(body);
  if (!parsed.success) {
    return NextResponse.json(
      { error: "invalid input", details: parsed.error.flatten() },
      { status: 400 },
    );
  }

  const { stream, sources } = await answerWithRag({
    question: parsed.data.question,
    documentIds: parsed.data.documentIds,
    history: [],
    topK: parsed.data.topK,
  });

  const encoder = new TextEncoder();
  const sseStream = new ReadableStream<Uint8Array>({
    async start(controller) {
      controller.enqueue(
        encoder.encode(
          `event: sources\ndata: ${JSON.stringify(sources)}\n\n`,
        ),
      );
      try {
        for await (const piece of stream) {
          controller.enqueue(encoder.encode(piece));
        }
      } catch (e) {
        const msg = e instanceof Error ? e.message : String(e);
        controller.enqueue(encoder.encode(`\n[error] ${msg}`));
      } finally {
        controller.close();
      }
    },
  });

  return new Response(sseStream, {
    headers: {
      "Content-Type": "text/event-stream",
      "Cache-Control": "no-cache",
      Connection: "keep-alive",
    },
  });
}
