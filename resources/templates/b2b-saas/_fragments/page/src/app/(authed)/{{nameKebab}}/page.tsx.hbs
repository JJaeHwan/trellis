import { getServerSession } from "next-auth";
import { redirect } from "next/navigation";
import { authOptions } from "@/lib/service/auth";

export const metadata = {
  title: "{{namePascal}}",
};

export default async function {{namePascal}}Page() {
  const session = await getServerSession(authOptions);
  if (!session?.user?.id) {
    redirect("/login");
  }

  return (
    <main className="mx-auto flex min-h-screen max-w-3xl flex-col gap-6 px-6 py-12">
      <h1 className="text-3xl font-bold">{{namePascal}}</h1>
      <p className="text-gray-600 dark:text-gray-400">
        Welcome, <span className="font-mono">{session.user.email}</span>
      </p>
      <section className="rounded-lg border p-6">
        <h2 className="mb-4 text-xl font-semibold">{{namePascal}} content</h2>
        <p className="text-sm text-gray-500">
          {/* TODO: implement {{namePascal}} UI */}
        </p>
      </section>
    </main>
  );
}
