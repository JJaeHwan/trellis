import { describe, it, expect, vi, beforeEach } from "vitest";
import { GET, POST } from "./route";

// ---------------------------------------------------------------------------
// Mocks
// ---------------------------------------------------------------------------

vi.mock("next-auth", () => ({
  getServerSession: vi.fn(),
}));

vi.mock("@/lib/service/auth", () => ({
  authOptions: {},
}));

vi.mock("@/lib/external/db", () => ({
  db: {
    {{nameCamel}}: {
      findMany: vi.fn(),
      create: vi.fn(),
    },
  },
}));

import { getServerSession } from "next-auth";
import { db } from "@/lib/external/db";

const mockSession = { user: { id: "user-1", email: "test@example.com", role: "USER" } };

// ---------------------------------------------------------------------------
// GET /api/{{nameKebab}}
// ---------------------------------------------------------------------------

describe("GET /api/{{nameKebab}}", () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  it("returns 401 when unauthenticated", async () => {
    vi.mocked(getServerSession).mockResolvedValueOnce(null);
    const res = await GET();
    expect(res.status).toBe(401);
    const body = await res.json() as { error: string };
    expect(body.error).toBe("unauthorized");
  });

  it("returns {{nameCamel}}s for authenticated user", async () => {
    vi.mocked(getServerSession).mockResolvedValueOnce(mockSession);
    const fakeItems = [{ id: "1", name: "test", userId: "user-1" }];
    vi.mocked(db.{{nameCamel}}.findMany).mockResolvedValueOnce(fakeItems);

    const res = await GET();
    expect(res.status).toBe(200);
    const body = await res.json() as { {{nameCamel}}s: unknown[] };
    expect(body.{{nameCamel}}s).toEqual(fakeItems);
  });
});

// ---------------------------------------------------------------------------
// POST /api/{{nameKebab}}
// ---------------------------------------------------------------------------

describe("POST /api/{{nameKebab}}", () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  it("returns 401 when unauthenticated", async () => {
    vi.mocked(getServerSession).mockResolvedValueOnce(null);
    const req = new Request("http://localhost/api/{{nameKebab}}", {
      method: "POST",
      body: JSON.stringify({ name: "test" }),
    });
    const res = await POST(req);
    expect(res.status).toBe(401);
  });

  it("returns 400 for invalid input", async () => {
    vi.mocked(getServerSession).mockResolvedValueOnce(mockSession);
    const req = new Request("http://localhost/api/{{nameKebab}}", {
      method: "POST",
      body: JSON.stringify({ name: "" }),
    });
    const res = await POST(req);
    expect(res.status).toBe(400);
  });

  it("creates and returns {{nameCamel}} for valid input", async () => {
    vi.mocked(getServerSession).mockResolvedValueOnce(mockSession);
    const created = { id: "2", name: "new", userId: "user-1" };
    vi.mocked(db.{{nameCamel}}.create).mockResolvedValueOnce(created);

    const req = new Request("http://localhost/api/{{nameKebab}}", {
      method: "POST",
      body: JSON.stringify({ name: "new" }),
    });
    const res = await POST(req);
    expect(res.status).toBe(201);
    const body = await res.json() as { {{nameCamel}}: unknown };
    expect(body.{{nameCamel}}).toEqual(created);
  });
});
