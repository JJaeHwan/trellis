name: CI

on:
  push:
    branches: [main]
  pull_request:

jobs:
  check:
    runs-on: ubuntu-latest
    env:
      DATABASE_URL: "file:./dev.db"
      NEXTAUTH_SECRET: "ci-only-not-a-real-secret-aaaaaaaaaaaaaaaa"
      NEXTAUTH_URL: "http://localhost:3000"
    steps:
      - uses: actions/checkout@v6

      - uses: actions/setup-node@v6
        with:
          node-version: 20
          cache: npm

      - run: npm ci
      - run: npx prisma generate
      - run: npm run typecheck
      - run: npm run lint
      - run: npm run test
      - run: npm run build
